  open-on-workspace "Tools"
  open-maximized true
}


window-rule {
  match app-id="sublime_merge" 
  open-on-workspace "Tools"
  open-maximized true
}


window-rule {
  match app-id="org.mozilla.Thunderbird" 
  open-on-workspace "Mail"
  open-maximized true
}

window-rule {
  match app-id="discord" 
  open-on-workspace "Mail"
  open-maximized true
}


window-rule {
  match app-id="org.telegram.desktop" 
  open-on-workspace "Mail"
  open-maximized true
}

window-rule {
  match app-id="obsidian" 
  open-on-workspace "Note"
  open-maximized true
}


window-rule {
  match app-id="Spotify" 
  open-on-workspace "Media"
  open-maximized true
