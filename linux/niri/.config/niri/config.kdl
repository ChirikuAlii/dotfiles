
input {
    disable-power-key-handling

    keyboard {
        xkb {
        }
        numlock
    }

    touchpad {
        // off
        tap
        // dwt
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "no-scroll"
    }

    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // scroll-button-lock
        // middle-emulation
    }

}

output "DP-1" {

  mode "1920x1080@60.000" 
  scale 1
  transform "normal"
  // position x=1280 y=0
}


layout { // Set gaps around windows in logical pixels.
    gaps 16

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 4
        active-color "#D08B57"
        inactive-color "#505050"
    }

    border {
        off
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    struts {
        // left 64
        // right 64
        // top 64
        // bottom 64
    }
}

spawn-at-startup "/usr/libexec/polkit-mate-authentication-agent-1"
spawn-at-startup "sh" "-c" "$HOME/.local/bin/wallpaper.sh"
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
spawn-at-startup "sh"  "-c" "waybar -c $XDG_CONFIG_HOME/waybar/config.jsonc" 
spawn-at-startup "niri" "msg" "action" "focus-workspace" "Terminal"
spawn-at-startup "wl-paste" "--type" "text" "--watch" "cliphist" "store"
spawn-at-startup "wl-paste" "--type" "image" "--watch" "cliphist" "store"

environment {
    ELECTRON_OZONE_PLATFORM_HINT "auto"
}

hotkey-overlay {
    // Uncomment this line to disable the "Important Hotkeys" pop-up at startup.
    // skip-at-startup
}
prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
animations {
    // Uncomment to turn off all animations.
    // off
    // Slow down all animations by this factor. Values below 1 speed them up instead.
    slowdown 0.5

    workspace-switch {
      spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001    
      off
    }
}


window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Open the Zen picture-in-picture player as floating by default.
window-rule {
    match app-id=r#"zen$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match title="^Gitnuro"
    default-column-width {}
}

window-rule {
    match title="^Guild Wars 2"
    default-column-width {}
    focus-ring {
        off
        // width 4
        // active-color "#D08B57"
        // inactive-color "#505050"
    }
}


window-rule {
    match app-id="Logseq"
    default-column-width {}
    open-on-workspace "Note"
    open-maximized true
}

window-rule {
    match app-id="foot"
    open-floating true
    // open-maximized true
    opacity 0.0  // atau 0.8 kalau mau kelihatan sedikit
    focus-ring {
        width 0
        // active-color "#D08B57"
        // inactive-color "#505050"
    }
    // default-column-width { fixed 800; } 
    // default-window-height { fixed 800; } 
    // default-column-width { fixed 1920; } 
    // default-window-height { fixed 1080; } 
    // default-floating-position x=20  y=20 relative-to="top-left"
}

window-rule {
    match app-id="waybar"
    geometry-corner-radius 19
    clip-to-geometry true
    draw-border-with-background false
}


workspace "File" {
  open-on-output "DP-1"
}


workspace "Media" {
  open-on-output "DP-1"
}


workspace "Mail" {
  open-on-output "DP-1"
}


workspace "Note" {
  open-on-output "DP-1"
}


workspace "Code" {
  open-on-output "DP-1"
}

workspace "Terminal" {
  open-on-output "DP-1"
}

workspace "Tools" {
  open-on-output "DP-1"
}

workspace "Browser" {
  open-on-output "DP-1"
}

window-rule {
  match app-id="google-chrome" 
  open-on-workspace "Browser"
  open-maximized true
}

window-rule {
  match app-id="firefox" 
  open-on-workspace "Browser"
  open-maximized true
}


window-rule {
  match title="Zen" 
  open-on-workspace "Browser"
  open-maximized true
}


window-rule {
  match app-id="Ai-Chat" 
  open-on-workspace "Browser"
  open-maximized true
}


